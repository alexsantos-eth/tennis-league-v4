---
import Heads from "../../../../layouts/heads.astro";
import Main from "../../../../layouts/main.astro";
import Page from "../../../../layouts/page.astro";
import ConfirmMatchScoreView from "@/views/match/[id]/confirm-score/client";

export const prerender = false;

const { id = "" } = Astro.params;
---

<Page>
  <Heads
    title="Confirmar resultado | Liga de Tenis GT"
    description="Confirma y registra el resultado final de un partido en la Liga de Tenis GT."
    noIndex
  />

  <body>
    <Main
      showFooter
      topbar={{
        title: "Confirmar resultado",
        goBack: true,
      }}
    >
      <ConfirmMatchScoreView client:load matchId={id} />
    </Main>
  </body>
</Page>
